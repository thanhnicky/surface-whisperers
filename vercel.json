{
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "redirects": [
    {
      "source": "/",
      "destination": "https://www.mocdienstudio.com",
      "statusCode": 308
    },
    {
      "source": "/:path*",
      "destination": "https://www.mocdienstudio.com/:path*",
      "statusCode": 308
    }
  ]
}
